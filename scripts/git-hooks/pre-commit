#!/bin/bash
# pre-commit hook: Run SwiftLint on staged Swift files
# Only blocks on errors (severity: error), warnings are allowed

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check if swiftlint is available
if ! command -v swiftlint &> /dev/null; then
    echo "⚠️  SwiftLint not installed, skipping lint check"
    echo "   Install: brew install swiftlint"
    exit 0
fi

echo "🔍 Running SwiftLint on staged files..."

HAS_ERRORS=false

for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        # Use --strict to treat warnings as errors only in CI, not here
        OUTPUT=$(swiftlint lint "$FILE" --quiet 2>&1)
        if [ -n "$OUTPUT" ]; then
            echo "$OUTPUT"
            # Check if any line contains "::error" (GitHub Actions error format)
            if echo "$OUTPUT" | grep -q "::error"; then
                HAS_ERRORS=true
            fi
        fi
    fi
done

if [ "$HAS_ERRORS" = true ]; then
    echo ""
    echo "❌ SwiftLint found errors. Please fix before committing."
    exit 1
fi

if [ -n "$OUTPUT" ]; then
    echo ""
    echo "⚠️  SwiftLint found warnings (non-blocking). Consider fixing them."
fi

echo "✅ SwiftLint passed (no errors)"
exit 0
